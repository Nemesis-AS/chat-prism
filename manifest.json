{
  "name": "ChatPrism",
  "description": "Enhances LLM chat interfaces with useful tools and utilities",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["clipboardWrite", "storage"],
  "content_scripts": [
    {
      "css": ["styles/colorizer.css"],
      "js": ["scripts/colorizer.js"],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ]
    }
  ]
}
