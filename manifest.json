{
  "name": "GPT Tools",
  "description": "An extension that adds some extra functionalities to ChatGPT",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["clipboardWrite", "storage"],
  "content_scripts": [
    {
      "css": ["styles/colorizer.css"],
      "js": ["scripts/colorizer.js"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}
